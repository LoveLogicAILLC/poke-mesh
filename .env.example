# ── Runtime ───────────────────────────────────────────────────────────────────
# Application environment: development | staging | production
NODE_ENV=development

# HTTP server port
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Full connection string for D1 or Turso (libSQL)
# e.g. libsql://your-db.turso.io or file:./dev.db
DATABASE_URL=

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Found in Cloudflare dashboard → right sidebar
CLOUDFLARE_ACCOUNT_ID=

# API token with Workers:Edit permission
# Create at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# ── Observability ─────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Poke-Mesh ─────────────────────────────────────────────────────────────────
# Interval (ms) between gossip protocol ticks
MESH_GOSSIP_INTERVAL_MS=5000

# Maximum number of agents allowed in the mesh
MESH_MAX_AGENTS=100

# Path to the mTLS Certificate Authority PEM file
MTLS_CA_PATH=./certs/ca.pem
