NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Mesh Configuration
MESH_GOSSIP_INTERVAL_MS=5000
MESH_MAX_AGENTS=100

# mTLS (local dev only)
MTLS_CA_PATH=./certs/ca.pem
MTLS_REQUIRE_CLIENT_CERT=false

# Cloudflare (for wrangler deploy)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# D1 Database (auto-configured by wrangler)
# DATABASE_URL is not needed — D1 is bound via wrangler.toml
